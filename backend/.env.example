# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy to .env for local development:  cp .env.example .env
# For production, set these in your hosting provider (e.g. Railway dashboard).
# =============================================================================

# --- Database -----------------------------------------------------------------
# Required. PostgreSQL connection string.
# Local:      postgres://localhost/medusa_db
# Railway:    Auto-provisioned by PostgreSQL plugin
DATABASE_URL=postgres://localhost/medusa_db

# --- Redis --------------------------------------------------------------------
# Optional locally (in-memory fallback). Required in production.
# When set, enables: caching-redis, event-bus-redis, workflow-engine-redis, locking-redis.
# Local:      redis://localhost:6379
# Railway:    Auto-provisioned by Redis plugin
# REDIS_URL=

# --- Security -----------------------------------------------------------------
# Auth token signing. Defaults to "supersecret" in development.
# Production: generate with `openssl rand -hex 32`
# medusa-config.ts will throw if these are insecure in production.
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# --- CORS ---------------------------------------------------------------------
# Comma-separated origins (protocol + host + port, no trailing slash).
# Must include every origin that makes requests to the backend.
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# --- Stripe -------------------------------------------------------------------
# Optional. When STRIPE_API_KEY is set, the Stripe payment module loads.
# Get keys from: https://dashboard.stripe.com/test/apikeys
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Note: STRIPE_WEBHOOK_SECRET is required in production when Stripe is enabled.

# --- Resend (email notifications) ---------------------------------------------
# Optional. When RESEND_API_KEY is set, the Resend notification module loads.
# Get key from: https://resend.com/api-keys
# RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@crowcommerce.org

# --- Storefront URL -----------------------------------------------------------
# Used in email templates for links (order confirmation, password reset, etc.).
# Set to your production storefront domain in production.
STOREFRONT_URL=http://localhost:3000

# --- Admin --------------------------------------------------------------------
# Public backend URL for the admin UI build. Only needed in production.
# MEDUSA_BACKEND_URL=https://api.example.com

# --- Admin Order Alerts -------------------------------------------------------
# Comma-separated email addresses to receive new order notifications.
# Requires Resend to be configured. Leave empty to disable.
# ADMIN_ORDER_EMAILS=admin@example.com,ops@example.com

# --- Cart Recovery ------------------------------------------------------------
# HMAC secret for abandoned cart recovery tokens.
# Must match CART_RECOVERY_SECRET in the storefront.
# Generate with: openssl rand -hex 32
# CART_RECOVERY_SECRET=
